<style>
body {
    font-family: Arial, sans-serif;
    margin: 0;
    background: #fbf5ff; /* Soft blush */
}

.navbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px;
    background: white;
    border-bottom: 2px solid #c272f4; /* Pink border */
}


.logo {
    font-size: 20px;
    font-weight: bold;
    color:#dec1f3
}

.search {
    padding: 5px;
    width: 250px;
}

.nav-links {
    display: flex;
    gap: 15px;
}

/* 🔹 Category Buttons */
.categories {
    display: flex;
    gap: 10px;
    padding: 15px;
}

.categories button {
    border: 1px solid #c472f4;
    background: white;
    color: #9418be;
}

.hero {
    margin: 20px;
    padding: 40px;
    text-align: center;
    border-radius: 10px;
    background: #fbf2fd; 
    border: 2px dashed #b572f4;
    color: #8918be;
}


.hero button {
    margin-top: 15px;
    padding: 10px 15px;
}

/* 🔹 Products Section */
.products {
    padding: 20px;
}

.product-grid {
    display: flex;
    gap: 20px;
    justify-content: space-between;
}

.card {
    background: white;
    border: 1px solid #eecffb;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    width: 22%;
    padding: 10px;
    text-align: center;
}

.image {
    height:320px;
    border-bottom: 1px solid black;
    margin-bottom: 10px;
}

.card button {
    background: #bc72f4;
    color: white;
    border: none;
    border-radius: 20px; /* Rounded pill style */
}

button,a {
    background: #d297e9;
    border: none;
    padding: 10px;
    border-radius: 5px;
    color: white;
    cursor: pointer;
    /* --- UPDATED: Transition for smoothness --- */
    transition: 0.3s;
    text-decoration: none;
}

button:active { 
    
    transform: scale(0.9);
}

button:hover {
    background: #9418be;
}
.button{
    background:#8918be;
    border: none;
    padding: 10px;
    border-radius: 5px;
    color:white;
    text-decoration: none;
}
img{
    height:300px;
    width:300px;
    
}
#pens,#pencils,#files{
    margin-top:50px;
}

</style>
</head>

